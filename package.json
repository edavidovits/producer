{
  "name": "producer",
  "productName": "Producer",
  "version": "1.0.2",
  "description": "PM workspace: Claude Code + file viewer",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --mac --dir && cp -r dist/mac-arm64/Producer.app /Applications/",
    "dist": "electron-builder --mac",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.eytan.producer",
    "productName": "Producer",
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dir",
        "dmg"
      ],
      "identity": "Producer Dev",
      "extendInfo": {
        "NSDocumentsFolderUsageDescription": "Producer needs access to your files to display them in the file viewer.",
        "NSDesktopFolderUsageDescription": "Producer needs access to your files to display them in the file viewer."
      }
    },
    "dmg": {
      "title": "Producer",
      "icon": "assets/icon.icns",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json"
    ]
  },
  "keywords": [],
  "author": "Eytan Davidovits",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.5",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
